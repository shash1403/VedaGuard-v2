# Copy to `.env.testnet` (gitignored) and set DEPLOYER_MNEMONIC.
# Fund the deployer on TestNet: https://bank.testnet.algorand.network/
# Or use the Dispenser API: `algokit dispenser login --ci` then set ALGOKIT_DISPENSER_ACCESS_TOKEN
# and run: poetry run python scripts/fund_testnet_demo_accounts.py
#
# AlgoKit loads this file when you run: algokit project deploy testnet

ALGOD_SERVER=https://testnet-api.algonode.cloud
ALGOD_TOKEN=

INDEXER_SERVER=https://testnet-idx.algonode.cloud
INDEXER_TOKEN=

# Optional — programmatic TestNet funding (see scripts/fund_testnet_demo_accounts.py).
# ALGOKIT_DISPENSER_ACCESS_TOKEN=

# Optional — pytest e2e (tests/e2e/test_testnet_dispenser_and_consent.py), same Algod as above:
# VEDAGUARD_E2E_APP_ID=123456789
# VEDAGUARD_E2E_SBT_ID=123456790
# VEDAGUARD_E2E_PRINCIPAL_MNEMONIC="25 words ..."   # wallet that holds the SBT + matches registry principal
# Requires ALGOKIT_DISPENSER_ACCESS_TOKEN for both e2e tests.

# Required —25-word mnemonic for an account with TestNet ALGO (see faucet above).
DEPLOYER_MNEMONIC=

# Optional — adult/child wallet for handoff demos & scripts/opt_in_child_to_sbt_testnet.py
# HANDOFF_CHILD_MNEMONIC=
