# --- Algod (pick one style) ---
# Option A: full URL (good for TestNet HTTPS)
# VITE_ALGOD_URL=https://testnet-api.algonode.cloud
# VITE_ALGOD_TOKEN=
#
# Option B: host + port (good for LocalNet)
# VITE_ALGOD_SERVER=http://localhost
# VITE_ALGOD_PORT=4001
# VITE_ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa

# Deployed VedaGuard app id (must include handoff + SBT box registry)
VITE_VEDAGUARD_APP_ID=1002

# SBT / consent ASA id from deploy (must match a registry box on VITE_VEDAGUARD_APP_ID).
# If unsure: connect wallet → Minors Registered → full detail lists on-chain SBT ASA ids.
VITE_CONSENT_ASSET_ID=1

# Optional: extra [VedaGuard] debug lines in the browser console (always verbose in `npm run dev`).
# VITE_VEDAGUARD_DEBUG=true

# Client-side Admin tab gate. Not cryptographic auth — deployer wallet enforces on-chain.
# VITE_ADMIN_DEMO_GATE=false
# VITE_ADMIN_DEMO_PASSWORD=admin
